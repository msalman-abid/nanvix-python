#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

NANVIX_HOME="${NANVIX_HOME:-}"
NANVIX_TOOLCHAIN="${NANVIX_TOOLCHAIN:-/opt/nanvix}"
NANVIX_PLATFORM="${NANVIX_PLATFORM:-hyperlight}"
NANVIX_PROCESS_MODE="${NANVIX_PROCESS_MODE:-multi-process}"
WORK_DIR="${WORK_DIR:-$ROOT_DIR/.nanvix}"
DOWNLOAD_DIR="$WORK_DIR/downloads"
SYSROOT="$WORK_DIR/sysroot"
TEST_START="${TEST_START:-1}"
TEST_END="${TEST_END:-999}"
TIMEOUT_SECONDS="${TIMEOUT_SECONDS:-300}"

log() {
  printf '[z] %s\n' "$*"
}

die() {
  printf '[z] error: %s\n' "$*" >&2
  exit 1
}

usage() {
  cat <<EOF
Usage: ./z <command>

Commands:
  setup    Download Nanvix runtime, init submodules, fetch CPython build deps.
  build    Build cymem, numpy, and CPython from source with built-in modules.
  test     Run smoke and functional tests on nanvixd.elf.
  release  Package runtime artifacts and standalone bundle for release.

Environment:
  NANVIX_PLATFORM     Target platform (default: hyperlight).
  NANVIX_PROCESS_MODE Process mode (default: multi-process).
  NANVIX_TOOLCHAIN    Toolchain root (default: /opt/nanvix).
  RELEASE_DIR         Output directory for release artifacts (default: ./release-assets).
  TEST_START           First test number to run (default: 1).
  TEST_END             Last test number to run (default: 999).
  TIMEOUT_SECONDS      Per-test timeout (default: 300).
EOF
}

curl_headers=()
if [[ -n "${GH_TOKEN:-}" ]]; then
  curl_headers=(-H "Authorization: Bearer ${GH_TOKEN}")
fi

cmd_setup() {
  mkdir -p "$DOWNLOAD_DIR" "$SYSROOT"

  # Download Nanvix runtime artifacts
  log "downloading Nanvix runtime artifacts"
  local nanvix_artifacts="$WORK_DIR/nanvix-artifacts"
  curl -fsSL https://raw.githubusercontent.com/nanvix/nanvix/refs/heads/dev/scripts/get-nanvix.sh | bash -s -- --force "$nanvix_artifacts"

  # Find and extract the matching platform artifact
  local nanvix_archive
  nanvix_archive="$(find "$nanvix_artifacts" -maxdepth 1 -type f -name "*.tar.bz2" | grep -E "${NANVIX_PLATFORM}.*${NANVIX_PROCESS_MODE}" | head -1)"
  if [[ -z "$nanvix_archive" ]]; then
    nanvix_archive="$(find "$nanvix_artifacts" -maxdepth 1 -type f -name "*.tar.bz2" | head -1)"
  fi
  [[ -z "$nanvix_archive" ]] && die "no Nanvix artifact found for ${NANVIX_PLATFORM}-${NANVIX_PROCESS_MODE}"
  log "extracting Nanvix runtime: $(basename "$nanvix_archive")"
  tar -xjf "$nanvix_archive" -C "$SYSROOT" --strip-components=0

  # Resolve sysroot directory
  if [[ -d "$SYSROOT/sysroot" ]]; then
    # Flatten: move sysroot/sysroot/* to sysroot/
    local tmp_sysroot="$WORK_DIR/_tmp_sysroot"
    mv "$SYSROOT/sysroot" "$tmp_sysroot"
    rm -rf "$SYSROOT"
    mv "$tmp_sysroot" "$SYSROOT"
  fi

  NANVIX_HOME="$SYSROOT"

  # Allow git operations in containerized CI where repository ownership
  # may differ from the executing user (e.g., root in job containers).
  log "configuring git safe directories"
  git config --global --add safe.directory "$ROOT_DIR"
  git config --global --add safe.directory "$ROOT_DIR/deps/cpython"
  git config --global --add safe.directory "$ROOT_DIR/deps/cymem"
  git config --global --add safe.directory "$ROOT_DIR/deps/numpy"
  git config --global --add safe.directory "$ROOT_DIR/deps/kiwi"
  git config --global --add safe.directory "$ROOT_DIR/deps/libexpat"
  git config --global --add safe.directory "$ROOT_DIR/deps/murmurhash"

  # Init/update git submodules
  log "initializing submodules"
  git submodule update --init --recursive --depth 1

  # Exclude build artifacts from submodule dirty tracking
  log "configuring submodule excludes"
  local cpython_gitdir cymem_gitdir numpy_gitdir kiwi_gitdir libexpat_gitdir murmurhash_gitdir
  cpython_gitdir="$(git -C "$ROOT_DIR/deps/cpython" rev-parse --git-dir)"
  cymem_gitdir="$(git -C "$ROOT_DIR/deps/cymem" rev-parse --git-dir)"
  numpy_gitdir="$(git -C "$ROOT_DIR/deps/numpy" rev-parse --git-dir)"
  kiwi_gitdir="$(git -C "$ROOT_DIR/deps/kiwi" rev-parse --git-dir)"
  libexpat_gitdir="$(git -C "$ROOT_DIR/deps/libexpat" rev-parse --git-dir)"
  murmurhash_gitdir="$(git -C "$ROOT_DIR/deps/murmurhash" rev-parse --git-dir)"
  grep -qxF 'Modules/cymem_builtin.c' "$cpython_gitdir/info/exclude" 2>/dev/null \
    || echo 'Modules/cymem_builtin.c' >> "$cpython_gitdir/info/exclude"
  grep -qxF 'Modules/kiwi_builtin.c' "$cpython_gitdir/info/exclude" 2>/dev/null \
    || echo 'Modules/kiwi_builtin.c' >> "$cpython_gitdir/info/exclude"
  grep -qxF 'Modules/murmurhash_builtin.c' "$cpython_gitdir/info/exclude" 2>/dev/null \
    || echo 'Modules/murmurhash_builtin.c' >> "$cpython_gitdir/info/exclude"
  grep -qxF 'libcymem.a' "$cymem_gitdir/info/exclude" 2>/dev/null \
    || echo 'libcymem.a' >> "$cymem_gitdir/info/exclude"
  grep -qxF 'builddir/' "$numpy_gitdir/info/exclude" 2>/dev/null \
    || echo 'builddir/' >> "$numpy_gitdir/info/exclude"
  grep -qxF 'nanvix-cross.ini' "$numpy_gitdir/info/exclude" 2>/dev/null \
    || echo 'nanvix-cross.ini' >> "$numpy_gitdir/info/exclude"
  grep -qxF '.nanvix-configured' "$numpy_gitdir/info/exclude" 2>/dev/null \
    || echo '.nanvix-configured' >> "$numpy_gitdir/info/exclude"
  grep -qxF '.nanvix-cython-bin/' "$numpy_gitdir/info/exclude" 2>/dev/null \
    || echo '.nanvix-cython-bin/' >> "$numpy_gitdir/info/exclude"
  grep -qxF 'libkiwisolver.a' "$kiwi_gitdir/info/exclude" 2>/dev/null \
    || echo 'libkiwisolver.a' >> "$kiwi_gitdir/info/exclude"
  grep -qxF '*.o' "$kiwi_gitdir/info/exclude" 2>/dev/null \
    || echo '*.o' >> "$kiwi_gitdir/info/exclude"
  grep -qxF 'libexpat.a' "$libexpat_gitdir/info/exclude" 2>/dev/null \
    || echo 'libexpat.a' >> "$libexpat_gitdir/info/exclude"
  grep -qxF '*.o' "$libexpat_gitdir/info/exclude" 2>/dev/null \
    || echo '*.o' >> "$libexpat_gitdir/info/exclude"
  grep -qxF 'expat_test.elf' "$libexpat_gitdir/info/exclude" 2>/dev/null \
    || echo 'expat_test.elf' >> "$libexpat_gitdir/info/exclude"
  grep -qxF 'libmurmurhash.a' "$murmurhash_gitdir/info/exclude" 2>/dev/null \
    || echo 'libmurmurhash.a' >> "$murmurhash_gitdir/info/exclude"
  grep -qxF '*.o' "$murmurhash_gitdir/info/exclude" 2>/dev/null \
    || echo '*.o' >> "$murmurhash_gitdir/info/exclude"

  # Install Cython in a virtual environment (required by the NumPy Meson build
  # to transpile .pyx files). The venv is created inside the work directory so
  # it is disposable and does not pollute the system Python.
  log "installing Cython and cppy"
  python3 -m venv "$WORK_DIR/venv"
  "$WORK_DIR/venv/bin/pip" install --quiet cython cppy
  export PATH="$WORK_DIR/venv/bin:$PATH"

  # Download CPython build dependencies (sqlite, zlib, openssl, bzip2, libffi)
  # via CPython's own setup script, reusing our NANVIX_HOME
  log "downloading CPython build dependencies"
  (
    cd "$ROOT_DIR/deps/cpython"
    NANVIX_HOME="$NANVIX_HOME" \
    NANVIX_TOOLCHAIN="$NANVIX_TOOLCHAIN" \
    NANVIX_PLATFORM="$NANVIX_PLATFORM" \
    NANVIX_PROCESS_MODE="$NANVIX_PROCESS_MODE" \
    GH_TOKEN="${GH_TOKEN:-}" \
    ./z setup
  )

  log "setup complete"
  log "SYSROOT=$SYSROOT"
}

# Helper: invoke make with Nanvix cross-compilation settings
nanvix_make() {
  local dir="$1"
  shift

  local make_args=(
    -f Makefile.nanvix
    CONFIG_NANVIX=y
    "NANVIX_HOME=$SYSROOT"
  )

  if [[ -n "$NANVIX_TOOLCHAIN" ]]; then
    make_args+=("NANVIX_TOOLCHAIN=$NANVIX_TOOLCHAIN")
  fi

  make -C "$dir" "${make_args[@]}" "$@"
}

# Helper: build numpy archives with Docker fallback because numpy's
# Makefile.nanvix expects a native toolchain path even when Docker is preferred.
nanvix_make_numpy() {
  local numpy_dir="$1"
  shift

  if [[ -n "$NANVIX_TOOLCHAIN" && -x "$NANVIX_TOOLCHAIN/bin/i686-nanvix-gcc" ]]; then
    nanvix_make "$numpy_dir" "$@"
    return
  fi

  command -v docker >/dev/null 2>&1 || die "docker not found and native Nanvix toolchain is unavailable"
  docker image inspect nanvix/toolchain:latest-minimal >/dev/null 2>&1 \
    || die "docker image nanvix/toolchain:latest-minimal not found"

  local host_cython_dir="/usr/lib/python3/dist-packages/Cython"
  [[ -d "$host_cython_dir" ]] || die "host Cython package not found at $host_cython_dir"

  local cython_shim_dir="$numpy_dir/.nanvix-cython-bin"
  mkdir -p "$cython_shim_dir"
  cat > "$cython_shim_dir/cython" <<'EOF'
#!/usr/bin/env sh
if [ "$#" -gt 0 ] && { [ "$1" = "-V" ] || [ "$1" = "--version" ]; }; then
  python3 - <<'PY'
import Cython
print(f"Cython version {Cython.__version__}")
PY
  exit 0
fi
exec python3 -m Cython.Compiler.Main "$@"
EOF
  chmod +x "$cython_shim_dir/cython"
  cp "$cython_shim_dir/cython" "$cython_shim_dir/cython3"

  docker run --rm \
    --user "$(id -u):$(id -g)" \
    -v "$numpy_dir:/mnt/workspace" \
    -v "$SYSROOT:/mnt/sysroot" \
    -v "$SYSROOT:/sysroot" \
    -v "$cython_shim_dir:/mnt/cython-bin:ro" \
    -v "$host_cython_dir:/mnt/host-cython/Cython:ro" \
    -w /mnt/workspace \
    -e HOME=/tmp \
    -e PYTHONPATH=/mnt/host-cython \
    -e PATH=/mnt/cython-bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
    nanvix/toolchain:latest-minimal \
    make -f Makefile.nanvix CONFIG_NANVIX=y NANVIX_HOME=/mnt/sysroot NANVIX_TOOLCHAIN=/opt/nanvix "$@"
}

cmd_build() {
  [[ -d "$SYSROOT" ]] || die "sysroot not found at $SYSROOT. Run './z setup' first."
  [[ -d "$ROOT_DIR/deps/cpython/Include" ]] || die "cpython submodule not initialized. Run './z setup' first."
  [[ -d "$ROOT_DIR/deps/cymem/cymem" ]] || die "cymem submodule not initialized. Run './z setup' first."
  [[ -d "$ROOT_DIR/deps/numpy/numpy" ]] || die "numpy submodule not initialized. Run './z setup' first."
  [[ -d "$ROOT_DIR/deps/kiwi/kiwi" ]] || die "kiwi submodule not initialized. Run './z setup' first."
  [[ -d "$ROOT_DIR/deps/murmurhash/murmurhash" ]] || die "murmurhash submodule not initialized. Run './z setup' first."
  [[ -d "$ROOT_DIR/deps/libexpat/expat" ]] || die "libexpat submodule not initialized. Run './z setup' first."

  # Activate the build virtual environment created by setup (provides Cython)
  if [[ -f "$WORK_DIR/venv/bin/activate" ]]; then
    source "$WORK_DIR/venv/bin/activate"
  fi

  local cpython_dir="$ROOT_DIR/deps/cpython"
  local cymem_dir="$ROOT_DIR/deps/cymem"
  local numpy_dir="$ROOT_DIR/deps/numpy"
  local kiwi_dir="$ROOT_DIR/deps/kiwi"
  local murmurhash_dir="$ROOT_DIR/deps/murmurhash"
  local libexpat_dir="$ROOT_DIR/deps/libexpat"

  # Step 1: Configure CPython (generates pyconfig.h and Makefile)
  log "configuring CPython"
  nanvix_make "$cpython_dir" configure

  # Step 2: Install CPython headers into sysroot so cymem can compile against them
  log "installing CPython headers into sysroot"
  mkdir -p "$SYSROOT/include/python3.12"
  cp -a "$cpython_dir"/Include/*.h "$SYSROOT/include/python3.12/"
  cp -a "$cpython_dir"/Include/cpython "$SYSROOT/include/python3.12/" 2>/dev/null || true
  cp -a "$cpython_dir"/Include/internal "$SYSROOT/include/python3.12/" 2>/dev/null || true
  cp "$cpython_dir/pyconfig.h" "$SYSROOT/include/python3.12/"

  # Step 3: Build cymem from source
  log "building cymem"
  nanvix_make "$cymem_dir" all
  cp "$cymem_dir/libcymem.a" "$SYSROOT/lib/"
  log "installed libcymem.a into sysroot"

  # Step 3a0: Build murmurhash from source
  log "building murmurhash"
  cp "$ROOT_DIR/patches/murmurhash_cwrap_nanvix.c" "$murmurhash_dir/murmurhash/murmurhash_cwrap.c"
  nanvix_make "$murmurhash_dir" all
  cp "$murmurhash_dir/libmurmurhash.a" "$SYSROOT/lib/"
  log "installed libmurmurhash.a into sysroot"

  # Step 3a: Build libexpat from source
  log "building libexpat"
  nanvix_make "$libexpat_dir" all
  cp "$libexpat_dir/libexpat.a" "$SYSROOT/lib/"
  cp "$libexpat_dir/expat/lib/expat.h" "$SYSROOT/include/"
  cp "$libexpat_dir/expat/lib/expat_external.h" "$SYSROOT/include/"
  log "installed libexpat.a into sysroot"

  # Step 3b: Build kiwisolver from source
  log "building kiwisolver"
  local cppy_include
  cppy_include="$(python3 -c "import cppy, os; print(os.path.join(os.path.dirname(cppy.__file__), 'include'))")"
  # Install cppy headers into sysroot/include so they are accessible via the
  # existing -I$(SYSROOT_INCLUDE) flag (works for both native and Docker builds).
  cp -a "$cppy_include"/* "$SYSROOT/include/"
  # Install kiwi C++ headers into sysroot so #include <kiwi/kiwi.h> resolves
  # inside Docker where $(CURDIR) host paths are not accessible.
  cp -a "$kiwi_dir/kiwi" "$SYSROOT/include/kiwi"
  # Point CPPY_INCLUDE to the Make-internal SYSROOT_INCLUDE variable so that
  # Docker path translation applies automatically.
  nanvix_make "$kiwi_dir" all 'CPPY_INCLUDE=$(SYSROOT_INCLUDE)'
  cp "$kiwi_dir/libkiwisolver.a" "$SYSROOT/lib/"
  log "installed libkiwisolver.a into sysroot"

  # Step 4: Patch numpy for static built-in module support (re-entrant init)
  log "patching numpy for static built-in support"
  (
    cd "$numpy_dir"
    if ! grep -q 'Nanvix.*re-entrant' numpy/core/src/multiarray/multiarraymodule.c 2>/dev/null; then
      git apply "$ROOT_DIR/patches/numpy_static_builtin.patch" 2>/dev/null \
        || log "numpy patch already applied or not needed"
    fi
    git apply "$ROOT_DIR/patches/numpy_makefile_nanvix.patch" 2>/dev/null \
      || log "numpy makefile patch already applied or not needed"
  )

  # Step 5: Build numpy static archives for CPython built-in modules
  log "building numpy archives"
  rm -rf "$numpy_dir/builddir" "$numpy_dir/.nanvix-configured" "$numpy_dir/nanvix-cross.ini"
  nanvix_make_numpy "$numpy_dir" all
  log "installed numpy archives into sysroot/lib/numpy"

  # Step 5: Prepare CPython to include cymem and numpy as built-in static modules.
  # makesetup rejects dotted names, so we register under the flat name "_cymem".
  # A Python-side shim (cymem/cymem.py) re-exports via `from _cymem import *`.
  log "patching CPython for cymem, kiwi, murmurhash, and numpy built-in modules"
  cp "$ROOT_DIR/patches/cymem_builtin.c" "$cpython_dir/Modules/"
  cp "$ROOT_DIR/patches/kiwi_builtin.c" "$cpython_dir/Modules/"
  cp "$ROOT_DIR/patches/murmurhash_builtin.c" "$cpython_dir/Modules/"
  cp "$ROOT_DIR/patches/numpy_libm_compat.c" "$cpython_dir/Modules/numpy_builtin/"
  local cpython_numpy_sysroot="$SYSROOT"
  if [[ -z "$NANVIX_TOOLCHAIN" || ! -x "$NANVIX_TOOLCHAIN/bin/i686-nanvix-gcc" ]]; then
    cpython_numpy_sysroot="/mnt/sysroot"
  fi
  local numpy_lib_dir="${cpython_numpy_sysroot}/lib/numpy"
  cat > "$cpython_dir/Modules/Setup.local" <<SETUP
# Built-in extensions for Nanvix (auto-generated by nanvix-python ./z build)
# cymem: Cython memory pool helper - linked statically as _cymem
*static*
_cymem cymem_builtin.c -lcymem

# kiwisolver: Cassowary constraint solver - linked statically as _kiwi_cext
_kiwi_cext kiwi_builtin.c -lkiwisolver -lstdc++

# murmurhash: Cython MurmurHash bindings - linked statically as _murmurhash_mrmr
_murmurhash_mrmr murmurhash_builtin.c -lmurmurhash -lstdc++

# numpy built-ins (flattened names due makesetup dotted-name restrictions)
_np_multiarray_umath numpy_builtin/_multiarray_umath_dummy.c numpy_builtin/numpy_libm_compat.c ${numpy_lib_dir}/lib_multiarray_umath_all.a ${numpy_lib_dir}/libnpymath.a
SETUP
  if [[ -f "${numpy_lib_dir}/lib_pocketfft_internal.a" ]]; then
    printf '%s\n' "_pocketfft_internal numpy_builtin/_pocketfft_internal_dummy.c ${numpy_lib_dir}/lib_pocketfft_internal.a ${numpy_lib_dir}/libnpymath.a" >> "$cpython_dir/Modules/Setup.local"
  fi
  rm -f "$cpython_dir/Modules/config.c"

  # Step 6: Build CPython with cymem/numpy linked in
  # makesetup detects the new Setup.local and regenerates config.c
  log "building CPython"
  nanvix_make "$cpython_dir" build

  # Step 7: Install CPython into sysroot
  log "installing CPython into sysroot"
  local staging="$cpython_dir/.nanvix/_install_staging"
  rm -rf "$staging"
  nanvix_make "$cpython_dir" install DESTDIR="$staging"
  cp -a "$staging/sysroot/." "$SYSROOT/"
  rm -rf "$staging"

  # Step 8: Install cymem Python-side shim so "from cymem.cymem import Pool" works
  log "installing cymem Python shim"
  local cymem_pkg="$SYSROOT/lib/python3.12/site-packages/cymem"
  mkdir -p "$cymem_pkg"
  cp "$ROOT_DIR/patches/cymem_shim.py" "$cymem_pkg/cymem.py"

  # Step 8b: Install kiwisolver Python package and _cext shim
  log "installing kiwisolver Python package"
  local kiwi_pkg="$SYSROOT/lib/python3.12/site-packages/kiwisolver"
  rm -rf "$kiwi_pkg"
  cp -a "$kiwi_dir/py/kiwisolver" "$kiwi_pkg"
  cp "$ROOT_DIR/patches/kiwi_cext_shim.py" "$kiwi_pkg/_cext.py"

  # Step 8c: Install murmurhash Python package and mrmr shim
  log "installing murmurhash Python package"
  local murmurhash_pkg="$SYSROOT/lib/python3.12/site-packages/murmurhash"
  rm -rf "$murmurhash_pkg"
  cp -a "$murmurhash_dir/murmurhash" "$murmurhash_pkg"
  cp "$ROOT_DIR/patches/murmurhash_mrmr_shim.py" "$murmurhash_pkg/mrmr.py"
  rm -f "$murmurhash_pkg"/*.pyx "$murmurhash_pkg"/*.pxd "$murmurhash_pkg"/*.c "$murmurhash_pkg"/*.cpp

  # Step 9: Install numpy Python package plus Nanvix import bootstrap
  log "installing numpy Python package"
  local numpy_pkg="$SYSROOT/lib/python3.12/site-packages/numpy"
  rm -rf "$numpy_pkg"
  cp -a "$numpy_dir/numpy" "$numpy_pkg"
  if [[ -f "$numpy_dir/builddir/numpy/version.py" ]]; then
    cp "$numpy_dir/builddir/numpy/version.py" "$numpy_pkg/version.py"
  else
    cat > "$numpy_pkg/version.py" << 'EOF'
version = "1.26.4"
__version__ = version
full_version = version
short_version = version
git_revision = "nanvix"
release = True
EOF
  fi

  cat > "$numpy_pkg/__config__.py" << 'EOF'
def show():
    return None

def get_info(*args, **kwargs):
    return {}
EOF

  rm -f "$numpy_pkg/__config__.py.in"

  # Remove __config__.py.in template, replaced by our stub above.
  rm -f "$numpy_pkg/__config__.py.in"

  cp "$ROOT_DIR/patches/nanvix_numpy_bootstrap.py" "$SYSROOT/lib/python3.12/sitecustomize.py"
  rm -f "$SYSROOT/lib/python3.12/site-packages/nanvix_numpy_bootstrap.pth"

  log "build complete"
  log "python3.12 at: $SYSROOT/bin/python3.12"
}

install_site_packages() {
  local site_pkg="$1"
  local pip_cmd=""
  local requirements_dir="$ROOT_DIR/requirements"

  if command -v pip3 >/dev/null 2>&1; then
    pip_cmd="pip3"
  elif [[ -n "$NANVIX_TOOLCHAIN" && -x "$NANVIX_TOOLCHAIN/bin/pip3" ]]; then
    pip_cmd="$NANVIX_TOOLCHAIN/bin/pip3"
  elif command -v python3 >/dev/null 2>&1 && python3 -m pip --version >/dev/null 2>&1; then
    pip_cmd="python3 -m pip"
  elif [[ -n "$NANVIX_TOOLCHAIN" && -x "$NANVIX_TOOLCHAIN/bin/python3" ]] && "$NANVIX_TOOLCHAIN/bin/python3" -m pip --version >/dev/null 2>&1; then
    pip_cmd="$NANVIX_TOOLCHAIN/bin/python3 -m pip"
  else
    log "pip3 not found; skipping site-packages installation"
    return 0
  fi

  $pip_cmd install --target="$site_pkg" --no-deps --no-compile --quiet \
    -r "$requirements_dir/site-packages-base.txt" \
    2>/dev/null || true

  $pip_cmd install --target="$site_pkg" --no-deps --no-compile --quiet \
    -r "$requirements_dir/site-packages-extra.txt" \
    2>/dev/null || true

  find "$site_pkg" -name "*.so" -delete 2>/dev/null || true
  rm -f "$site_pkg/distutils-precedence.pth" 2>/dev/null || true
}

run_smoke_test() {
  local test_sysroot="$1"
  local log_file="/tmp/smoke.log"

  cp "$ROOT_DIR/tests/smoke_test_l2.py" "$test_sysroot/"

  cd "$test_sysroot"
  timeout "$TIMEOUT_SECONDS" ./bin/nanvixd.elf -- ./bin/python3.12 ./smoke_test_l2.py < /dev/null > "$log_file" 2>&1 || true

  if grep -q 'FAIL' "$log_file" 2>/dev/null; then
    cat "$log_file" || true
    rm -f "$log_file"
    die "smoke test failed"
  fi

  if grep -q 'PASS' "$log_file" 2>/dev/null; then
    log "smoke test: PASS"
  elif [[ -s "$log_file" ]]; then
    log "smoke test output:"
    cat "$log_file" || true
  else
    rm -f "$log_file"
    die "smoke test produced no output"
  fi

  rm -f "$log_file"
}

run_functional_tests() {
  local test_sysroot="$1"
  local total_pass=0
  local total_fail=0
  local total_skip=0
  local failed_tests=""

  # Copy individual test files into the test sysroot
  cp "$ROOT_DIR"/tests/func/test_*.py "$test_sysroot/" 2>/dev/null || true

  # Optionally precompile stdlib and tests
  local host_python=""
  if [[ -n "$NANVIX_TOOLCHAIN" && -x "$NANVIX_TOOLCHAIN/bin/python3" ]]; then
    host_python="$NANVIX_TOOLCHAIN/bin/python3"
  elif command -v python3 >/dev/null 2>&1; then
    host_python="python3"
  fi
  if [[ -n "$host_python" ]]; then
    "$host_python" -m compileall -q "$test_sysroot/lib/python3.12/" 2>/dev/null || true
    "$host_python" -m compileall -q "$test_sysroot"/test_*.py 2>/dev/null || true
  fi

  # Run each test individually
  for test_file in "$test_sysroot"/test_[0-9]*.py; do
    [[ ! -f "$test_file" ]] && continue
    local test_basename
    test_basename=$(basename "$test_file")

    # Extract test number for range filtering
    local test_num
    test_num=$(echo "$test_basename" | grep -oP '(?<=test_)\d+' | sed 's/^0*//' )
    [[ -z "$test_num" ]] && test_num=0
    [[ "$test_num" -lt "$TEST_START" || "$test_num" -gt "$TEST_END" ]] && continue

    local log_file="/tmp/${test_basename}.log"
    cd "$test_sysroot"
    timeout "$TIMEOUT_SECONDS" ./bin/nanvixd.elf -- ./bin/python3.12 "./$test_basename" < /dev/null > "$log_file" 2>&1 || true

    if grep -q 'PASS' "$log_file" 2>/dev/null; then
      local test_name
      test_name=$(grep 'PASS' "$log_file" | head -1 | sed 's/:.*//')
      echo "  $test_name: PASS"
      total_pass=$((total_pass + 1))
    elif grep -q 'FAIL' "$log_file" 2>/dev/null; then
      grep 'FAIL' "$log_file" 2>/dev/null || true
      total_fail=$((total_fail + 1))
      failed_tests="${failed_tests}${test_basename} "
    else
      echo "  ${test_basename}: SKIP"
      total_skip=$((total_skip + 1))
    fi

    rm -f "$log_file"
  done

  echo "Results: ${total_pass} passed, ${total_fail} failed, ${total_skip} skipped"

  if [[ "$total_fail" -gt 0 ]]; then
    echo "Failed tests: ${failed_tests}"
    exit 1
  fi

  if [[ "$total_pass" -eq 0 ]]; then
    die "no tests passed (all skipped or none found)"
  fi

  echo "All functional tests passed"
}

cmd_test() {
  [[ -d "$SYSROOT" ]] || die "sysroot not found at $SYSROOT. Run './z setup' first."
  [[ -x "$SYSROOT/bin/nanvixd.elf" ]] || die "missing executable: $SYSROOT/bin/nanvixd.elf"
  [[ -x "$SYSROOT/bin/python3.12" ]] || die "missing executable: $SYSROOT/bin/python3.12. Run './z build' first."

  local site_pkg="$SYSROOT/lib/python3.12/site-packages"
  mkdir -p "$site_pkg"

  install_site_packages "$site_pkg"
  run_smoke_test "$SYSROOT"
  run_functional_tests "$SYSROOT"
}

cmd_release() {
  [[ -d "$SYSROOT" ]] || die "sysroot not found at $SYSROOT. Run './z setup' first."
  [[ -x "$SYSROOT/bin/nanvixd.elf" ]] || die "missing executable: $SYSROOT/bin/nanvixd.elf"
  [[ -x "$SYSROOT/bin/python3.12" ]] || die "missing executable: $SYSROOT/bin/python3.12. Run './z build' first."

  local release_dir="${RELEASE_DIR:-$ROOT_DIR/release-assets}"
  local asset_prefix="${NANVIX_PLATFORM}-${NANVIX_PROCESS_MODE}"
  local nanvix_artifacts="$WORK_DIR/nanvix-artifacts"
  local bundle_root="$WORK_DIR/release-bundle"
  local bundle_dir="$bundle_root/$asset_prefix"

  log "release: preparing artifacts for ${asset_prefix}"
  log "release: output directory: $release_dir"

  mkdir -p "$release_dir" "$bundle_dir"

  log "release: copying Nanvix runtime archives"
  for archive in "$nanvix_artifacts"/*.tar.bz2; do
    [[ -f "$archive" ]] || continue
    cp -a "$archive" "$release_dir/${asset_prefix}-$(basename "$archive")"
    log "release: added $(basename "$archive")"
  done

  log "release: building standalone bundle layout"
  cp -a "$SYSROOT" "$bundle_dir/sysroot"

  cat > "$bundle_dir/run-python.sh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/sysroot"
exec ./bin/nanvixd.elf -- ./bin/python3.12 "$@"
EOF
  chmod +x "$bundle_dir/run-python.sh"

  cat > "$bundle_dir/README.md" <<EOF
# Standalone Runtime Bundle

Platform: ${NANVIX_PLATFORM}
Process mode: ${NANVIX_PROCESS_MODE}

## Usage

After extracting the archive, enter this directory and run:

./run-python.sh -c 'print(123)'

Or execute a script:

./run-python.sh ./your_script.py
EOF

  log "release: validating standalone launcher"
  "$bundle_dir/run-python.sh" -c 'print(123)' >/dev/null 2>&1 || die "standalone bundle validation failed"

  log "release: creating standalone tarball"
  tar -cjf "$release_dir/standalone-runtime-${asset_prefix}.tar.bz2" -C "$bundle_root" "$asset_prefix"
  rm -rf "$bundle_root"

  log "release: standalone tarball: $release_dir/standalone-runtime-${asset_prefix}.tar.bz2"
  log "release artifacts written to: $release_dir"
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
  setup)
    cmd_setup
    ;;
  build)
    cmd_build
    ;;
  test)
    cmd_test
    ;;
  release)
    cmd_release
    ;;
  *)
    usage
    exit 1
    ;;
esac
